  "original" : "Why?",
  "traduzido" : "Por que?",
  "idiomaOriginal" : "en",
  "idiomaTraduzido" : "pt-br"
}, {
  "indice" : 21,
  "estilo" : "Default",
  "original" : "Because I just can't.",
  "traduzido" : "Porque simplesmente não consigo.",
  "idiomaOriginal" : "en",
  "idiomaTraduzido" : "pt-br"
}, {
  "indice" : 22,
