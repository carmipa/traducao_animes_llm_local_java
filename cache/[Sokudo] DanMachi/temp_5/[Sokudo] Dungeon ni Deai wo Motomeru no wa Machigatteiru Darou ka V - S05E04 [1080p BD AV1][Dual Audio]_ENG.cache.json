  "traduzido" : "Q-Que diabos isso quer dizer?",
  "idiomaOriginal" : "en",
  "idiomaTraduzido" : "pt-br"
}, {
  "indice" : 30,
  "estilo" : "Default",
  "original" : "I don't get it.",
  "traduzido" : "Eu não entendo.",
  "idiomaOriginal" : "en",
  "idiomaTraduzido" : "pt-br"
}, {
  "indice" : 31,
  "estilo" : "Default",
  "original" : "So, uh, Ms. Syr? I was wondering...",
  "traduzido" : "Então, uh, Srta. Syr? Eu estava me perguntando...",
  "idiomaOriginal" : "en",
  "idiomaTraduzido" : "pt-br"
}, {
  "indice" : 32,
  "estilo" : "Default",
